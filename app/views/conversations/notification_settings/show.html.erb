<% content_for :title, "Notificações – #{@conversation.display_name_for(current_user)}" %>

<div class="flex h-screen bg-[#111b21]">
  <div class="w-full max-w-xl mx-auto p-6">
    <div class="flex items-center gap-4 mb-6">
      <%= link_to conversation_path(@conversation), class: "text-[#8696a0] hover:text-white transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <h1 class="text-white text-xl font-medium">Notificações desta conversa</h1>
    </div>

    <div class="bg-[#202c33] rounded-2xl p-6" data-controller="notification-settings" data-notification-settings-max-seconds-value="6">
      <%= form_with model: @participant, url: conversation_notification_settings_path(@conversation), method: :patch, class: "space-y-5" do |f| %>
        <% if @participant.errors.any? %>
          <div class="rounded-lg bg-amber-500/10 border border-amber-500/30 px-4 py-3 text-amber-400 text-sm">
            <ul class="list-disc list-inside">
              <% @participant.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex items-center justify-between py-1">
          <div>
            <span class="text-white text-sm font-medium">Silenciar notificações</span>
            <p class="text-[#8696a0] text-xs mt-0.5">Nenhum som nem notificação push desta conversa.</p>
          </div>
          <%= f.check_box :muted, class: "rounded border-[#2a3942] bg-[#2a3942] text-[#00a884] focus:ring-[#00a884]" %>
        </div>

        <div>
          <%= f.label :notification_sound, "Som padrão", class: "block text-[#8696a0] text-xs font-semibold mb-1 uppercase tracking-wide" %>
          <p class="text-[#8696a0] text-xs mb-2">Ou use um áudio customizado abaixo.</p>
          <%= f.select :notification_sound,
                options_for_select(
                  [ [ "Usar padrão do perfil", "" ] ] + NotificationPreferences::DEFAULT_SOUNDS.map { |s| [ s[:name], s[:id] ] },
                  @participant.notification_sound
                ),
                {},
                class: "w-full bg-[#2a3942] text-white rounded-lg px-4 py-3 text-sm outline-none border border-transparent focus:border-[#00a884]" %>
        </div>

        <div>
          <span class="block text-[#8696a0] text-xs font-semibold mb-1 uppercase tracking-wide">Áudio customizado</span>
          <p class="text-[#8696a0] text-xs mb-2">Máximo 6 segundos. MP3, WAV ou similar.</p>
          <% if @participant.notification_sound_file.attached? %>
            <p class="text-[#aebac1] text-sm mb-2">Arquivo atual anexado. Envie outro para substituir.</p>
          <% end %>
          <%= f.file_field :notification_sound_file, accept: "audio/*", class: "w-full text-sm text-[#8696a0] file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-[#00a884] file:text-white file:text-sm" %>
        </div>

        <div>
          <%= f.label :notification_color, "Cor do ícone (hex)", class: "block text-[#8696a0] text-xs font-semibold mb-1 uppercase tracking-wide" %>
          <div class="flex gap-2 items-center">
            <%= f.color_field :notification_color,
                  value: @participant.notification_color.presence || "#00a884",
                  class: "h-10 w-14 rounded border-0 bg-[#2a3942] cursor-pointer" %>
            <%= f.text_field :notification_color,
                  placeholder: "#00a884 ou vazio = padrão",
                  class: "flex-1 bg-[#2a3942] text-white rounded-lg px-4 py-3 text-sm outline-none border border-transparent focus:border-[#00a884]" %>
          </div>
        </div>

        <div>
          <span class="block text-[#8696a0] text-xs font-semibold mb-2 uppercase tracking-wide">Ícone da notificação</span>
          <p class="text-[#8696a0] text-xs mb-3">O que aparece no toast quando chega mensagem.</p>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.radio_button :notification_icon_type, "avatar", class: "text-[#00a884]" %>
              <span class="text-white text-sm">Foto do contato</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.radio_button :notification_icon_type, "color", class: "text-[#00a884]" %>
              <span class="text-white text-sm">Cor sólida</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.radio_button :notification_icon_type, "custom_image", class: "text-[#00a884]" %>
              <span class="text-white text-sm">Minha imagem</span>
            </label>
          </div>
        </div>

        <div>
          <span class="block text-[#8696a0] text-xs font-semibold mb-1 uppercase tracking-wide">Imagem customizada</span>
          <p class="text-[#8696a0] text-xs mb-2">Usada quando “Minha imagem” está selecionado acima.</p>
          <% if @participant.notification_custom_image.attached? %>
            <p class="text-[#aebac1] text-sm mb-2">Imagem atual anexada. Envie outra para substituir.</p>
          <% end %>
          <%= f.file_field :notification_custom_image, accept: "image/*", class: "w-full text-sm text-[#8696a0] file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:bg-[#00a884] file:text-white file:text-sm" %>
        </div>

        <%= f.submit "Salvar",
              class: "w-full bg-[#00a884] hover:bg-[#02966f] text-white font-semibold py-3 rounded-lg text-sm transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>

<% content_for :title, @conversation.display_name_for(current_user) %>
<%# Evita cache do Turbo nesta página: aba aberta há tempo sempre recebe conteúdo fresco e status atualizado %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="flex h-screen bg-[#111b21]"
     data-controller="chat user-inbox"
     data-chat-conversation-id-value="<%= @conversation.id %>"
     data-chat-interactive-locked-value="<%= @participant&.interactively_locked? %>"
     data-user-inbox-user-id-value="<%= current_user.id %>">

  <%# SIDEBAR (reloaded with current conversation highlighted) %>
  <div class="w-[400px] min-w-[400px] flex flex-col border-r border-[#2a3942] bg-[#111b21]">

    <%# Sidebar Header %>
    <div class="flex items-center justify-between px-4 py-3 bg-[#202c33]">
      <%= link_to profile_path, class: "flex items-center gap-3" do %>
        <% if current_user.avatar.attached? %>
          <%= image_tag current_user.avatar, class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <div class="w-10 h-10 rounded-full bg-[#6a7175] flex items-center justify-center text-white font-semibold text-sm">
            <%= current_user.display_name.first.upcase %>
          </div>
        <% end %>
      <% end %>

      <div class="flex items-center gap-2 ml-auto">
        <%= link_to templates_path, class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h10" />
          </svg>
        <% end %>
        <% if current_user.role_admin? || current_user.company_attendants.supervisors.any? %>
          <%= link_to admin_root_path, class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors", title: "Admin" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#00a884]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          <% end %>
        <% end %>
        <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
              class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1" />
          </svg>
        <% end %>
      </div>
    </div>

    <%# Search %>
    <div class="px-3 py-2 bg-[#111b21]">
      <div class="flex items-center bg-[#202c33] rounded-lg px-4 py-2 gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#8696a0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
        </svg>
        <input type="text" placeholder="Pesquisar conversas"
               class="bg-transparent text-[#d1d7db] placeholder-[#8696a0] text-sm outline-none w-full"
               data-action="input->conversation-search#filter">
      </div>
    </div>

    <%# Conversations list %>
    <div class="flex-1 overflow-y-auto" data-controller="conversation-search">
      <% current_user.conversations.includes(:users, :messages).recent.each do |convo| %>
        <div id="conversation-item-wrapper-<%= convo.id %>" class="<%= 'bg-[#2a3942]' if convo.id == @conversation.id %>">
          <%= render "conversations/conversation_item", conversation: convo, current_user: current_user %>
        </div>
      <% end %>
    </div>
  </div>

  <%# MAIN CHAT PANEL %>
  <div class="flex-1 flex flex-col bg-[#0b141a] relative">

    <%# Chat header %>
    <div class="flex items-center gap-3 px-4 py-3 bg-[#202c33] border-b border-[#2a3942] relative">
      <%= link_to root_path, class: "md:hidden p-1 mr-1" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>

      <% if @conversation.conversation_type_group? %>
        <div class="w-10 h-10 rounded-full bg-[#6a7175] flex items-center justify-center flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2h5M12 12a4 4 0 100-8 4 4 0 000 8z" />
          </svg>
        </div>
      <% else %>
        <% other = @conversation.other_user(current_user) %>
        <div class="w-10 h-10 rounded-full flex-shrink-0 overflow-hidden flex items-center justify-center bg-[#6a7175]"
             id="contact-presence-avatar">
          <% if other&.avatar&.attached? %>
            <%= image_tag other.avatar, class: "w-full h-full object-cover", alt: other.display_name %>
          <% else %>
            <span class="text-white font-semibold text-sm"><%= other&.display_name&.first&.upcase || "?" %></span>
          <% end %>
        </div>
      <% end %>

      <div class="flex-1 min-w-0">
        <% if @had_unread.to_i > 0 %>
          <p class="text-[#00a884] text-xs font-medium mb-0.5"><%= @had_unread == 1 ? "1 mensagem não lida" : "#{@had_unread} mensagens não lidas" %></p>
        <% end %>
        <h2 class="text-white font-medium text-sm"><%= @conversation.display_name_for(current_user) %></h2>
        <p class="text-[#8696a0] text-xs" id="contact-status">
          <% if @conversation.conversation_type_direct? %>
            <%= @conversation.other_user(current_user)&.display_last_seen %>
          <% else %>
            <%= @conversation.users.map(&:display_name).join(", ").truncate(60) %>
          <% end %>
        </p>
      </div>

      <%# Voice / Video call buttons (direct chats only) %>
      <% if @conversation.conversation_type_direct? %>
        <% other = @conversation.other_user(current_user) %>
        <%# Audio call %>
        <button data-action="click->call#startCall"
                data-user-id="<%= other&.id %>"
                data-call-type="audio"
                data-conversation-id="<%= @conversation.id %>"
                class="p-2 rounded-full hover:bg-[#2a3942] transition-colors"
                title="Chamada de voz">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </button>
        <%# Video call %>
        <button data-action="click->call#startCall"
                data-user-id="<%= other&.id %>"
                data-call-type="video"
                data-conversation-id="<%= @conversation.id %>"
                class="p-2 rounded-full hover:bg-[#2a3942] transition-colors"
                title="Chamada de vídeo">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.882v6.236a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </button>
      <% end %>

      <div class="flex items-center gap-1"
           data-controller="message-search"
           data-message-search-url-value="<%= search_conversation_messages_path(@conversation) %>">
        <%# Search button %>
        <button data-action="click->message-search#toggle"
                class="p-2 rounded-full hover:bg-[#2a3942] transition-colors" title="Buscar mensagens">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#aebac1]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
          </svg>
        </button>

        <%# Notification settings %>
        <%= link_to conversation_notification_settings_path(@conversation),
              class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors text-[#aebac1] hover:text-white",
              title: "Configurar notificações" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        <% end %>

        <%# Archive button %>
        <%= button_to archive_conversation_path(@conversation), method: :patch,
              class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors text-[#aebac1] hover:text-white",
              title: "Arquivar conversa" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
          </svg>
        <% end %>

        <%# Pin button %>
        <% participant = @conversation.participants.find_by(user: current_user) %>
        <%= button_to toggle_pin_conversation_path(@conversation), method: :patch,
              class: "p-2 rounded-full hover:bg-[#2a3942] transition-colors #{participant&.pinned? ? 'text-[#00a884]' : 'text-[#aebac1]'}",
              title: participant&.pinned? ? "Desafixar" : "Fixar conversa" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
        <% end %>

        <%# Search panel (hidden by default) %>
        <div data-message-search-target="panel"
             class="hidden absolute top-16 right-0 w-80 bg-[#202c33] border border-[#2a3942] rounded-xl shadow-2xl z-30">
          <div class="p-3 border-b border-[#2a3942] flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#8696a0]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>
            <input type="text" placeholder="Buscar mensagens..."
                   data-message-search-target="input"
                   data-action="input->message-search#search"
                   class="bg-transparent text-white placeholder-[#8696a0] text-sm outline-none flex-1">
            <button data-action="click->message-search#close" class="text-[#8696a0] hover:text-white">✕</button>
          </div>
          <div data-message-search-target="results" class="max-h-80 overflow-y-auto"></div>
        </div>
      </div>
    </div>

    <%# Typing indicator %>
    <div id="typing-indicator"
         class="hidden px-6 py-1 text-[#8696a0] text-xs italic">
      <span id="typing-user-name"></span> está digitando...
    </div>

    <%# Messages area — sem turbo-permanent para ao clicar noutra conversa carregar as mensagens certas %>
    <div class="flex-1 flex flex-col min-h-0 overflow-hidden">
      <div class="flex-1 overflow-y-auto px-4 py-4 min-h-0"
           id="messages-container"
           data-controller="scroll-to-bottom"
           data-action="turbo:load->scroll-to-bottom#scroll"
           style="background-color: #0b141a;">

        <%# Infinite scroll trigger (top) — shown when there are more pages %>
        <% if @pagy.page < @pagy.pages %>
          <%= render "messages/load_more",
                conversation: @conversation,
                next_page: @pagy.page + 1 %>
        <% end %>

        <div id="messages" data-chat-target="messages" class="min-w-0 flex flex-col">
        <% prev_message = nil %>
        <% @messages.each do |message| %>
          <% if @first_unread_message_id == message.id %>
            <div class="flex justify-center my-3" id="unread-divider"
                 data-controller="unread-divider"
                 data-unread-divider-delay-ms-value="15000">
              <span class="bg-[#00a884] text-white text-xs font-medium px-4 py-1.5 rounded-full">
                <%= @had_unread == 1 ? "1 mensagem não lida" : "#{@had_unread} mensagens não lidas" %>
              </span>
            </div>
          <% end %>
          <%= render "messages/message", message: message, current_user: current_user, same_sender_as_previous: (prev_message && prev_message.sender_id == message.sender_id), first_in_list: prev_message.nil? %>
          <% prev_message = message %>
        <% end %>
      </div>

        <%# Scroll anchor — JS scrolla até aqui ao carregar %>
        <div id="messages-bottom"></div>
      </div>
    </div>

    <%# Barra de seleção de imagens (modo "Selecionar mais") %>
    <div id="image-selection-bar"
         data-controller="image-selection-bar"
         class="hidden fixed bottom-20 left-0 md:left-[400px] right-0 z-50 flex justify-center py-3 bg-[#202c33] border-t border-[#2a3942] shadow-lg">
      <div class="flex items-center gap-4">
        <span class="text-[#d1d7db] text-sm" data-image-selection-bar-target="count">0 imagens selecionadas</span>
        <button type="button"
                data-action="click->image-selection-bar#downloadSelected"
                class="px-4 py-2 rounded-lg bg-[#00a884] text-white hover:bg-[#02966f] transition-colors text-sm font-medium">
          Descarregar seleção
        </button>
        <button type="button"
                data-action="click->image-selection-bar#cancel"
                class="px-4 py-2 rounded-lg bg-[#2a3942] text-[#d1d7db] hover:bg-[#3d4a52] transition-colors text-sm">
          Cancelar
        </button>
      </div>
    </div>

    <%# Message input area — file-preview controller must wrap the input for change->file-preview#showPreview %>
    <div class="px-4 py-3 bg-[#202c33] border-t border-[#2a3942]" data-controller="file-preview">

      <%# Reply banner — shown when user taps "Responder" on a message %>
      <div id="reply-banner"
           style="display:none;"
           class="flex items-center gap-2 mb-2 px-3 py-2 bg-[#2a3942] rounded-xl border-l-4 border-[#00a884]">
        <%# Thumbnail (for images/stickers) %>
        <img id="reply-banner-thumb" src="" alt="" style="display:none;"
             class="w-10 h-10 object-cover rounded-lg flex-shrink-0" />
        <%# Text preview %>
        <div class="flex-1 min-w-0">
          <p id="reply-banner-name" class="text-[#00a884] text-xs font-semibold truncate"></p>
          <p id="reply-banner-text" class="text-[#8696a0] text-xs truncate"></p>
        </div>
        <%# Close (cancel reply) %>
        <button type="button"
                onclick="document.getElementById('reply-banner').style.display='none'; document.getElementById('reply-to-id-field').value='';"
                class="text-[#8696a0] hover:text-white flex-shrink-0 p-1 rounded-full hover:bg-white/10 transition-colors"
                title="Cancelar resposta">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# File preview %>
      <div id="file-preview" class="hidden mb-3 p-3 bg-[#2a3942] rounded-lg flex flex-wrap items-center gap-3">
        <div id="file-preview-content" class="flex-1 flex flex-wrap gap-3 min-w-0"></div>
        <button type="button" id="file-preview-remove" class="text-[#8696a0] hover:text-white flex-shrink-0" title="Remover anexos">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <%= form_with scope: :message,
                    url: conversation_messages_path(@conversation, format: :turbo_stream),
                    method: :post,
                    data: {
                      controller: "composer-emoji",
                      composer_emoji_emojis_value: MessageReaction::ALLOWED_EMOJIS,
                      chat_target: "form",
                      action: "submit->chat#submitForm turbo:submit-end->chat#resetForm"
                    },
                    class: "flex items-end gap-2" do |f| %>
        <%# client_message_id: um por envio; servidor usa para idempotência (evitar duplicata do mesmo envio) %>
        <%= f.hidden_field :client_message_id, value: "", data: { chat_target: "clientMessageId" } %>
        <%# reply_to_id: preenchido pelo reply_controller quando o usuário toca "Responder" %>
        <%= f.hidden_field :reply_to_id, value: "", id: "reply-to-id-field" %>

        <%# Emoji picker (composer) %>
        <div class="relative flex-shrink-0 mb-1">
          <button type="button"
                  data-action="click->composer-emoji#toggle"
                  class="p-2 text-[#8696a0] hover:text-white transition-colors"
                  title="Emoji">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </button>
          <div data-composer-emoji-target="panel"
               class="hidden absolute bottom-full mb-2 left-0 bg-[#233138] border border-[#2a3942] rounded-2xl shadow-xl p-2 flex items-center gap-1 z-40 max-w-[min(90vw,22rem)]">
            <div class="flex items-center gap-1 flex-wrap" data-composer-emoji-target="favorites"></div>
            <button type="button"
                    data-action="click->composer-emoji#openMore"
                    class="ml-1 px-2 py-1 rounded-lg border border-[#2a3942] text-xs text-[#8696a0] hover:text-white hover:bg-[#2a3942] transition-colors">
              Mais
            </button>
          </div>
        </div>

        <%# Emoji modal (all emojis) %>
        <div data-composer-emoji-target="modal"
             class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4"
             aria-modal="true" role="dialog">
          <div class="absolute inset-0 bg-black/60"></div>
          <div class="relative w-full max-w-md bg-[#202c33] border border-[#2a3942] rounded-2xl shadow-2xl p-3">
            <div class="flex items-center justify-between mb-2">
              <p class="text-white text-sm font-medium">Emojis</p>
              <button type="button" data-action="click->composer-emoji#close" class="text-[#8696a0] hover:text-white">✕</button>
            </div>
            <div class="max-h-[60vh] overflow-y-auto pr-1 space-y-3">
              <% MessageReaction::EMOJI_CATEGORIES.each do |category, emojis| %>
                <% next if category == "Recentes / Favoritos" %>
                <div>
                  <p class="text-[#8696a0] text-xs font-semibold uppercase tracking-wide mb-2"><%= category %></p>
                  <div class="flex flex-wrap gap-1">
                    <% emojis.each do |emoji| %>
                      <button type="button"
                              data-action="click->composer-emoji#pick"
                              data-emoji="<%= emoji %>"
                              class="text-2xl hover:scale-125 transition-transform p-2 rounded-xl hover:bg-[#2a3942]">
                        <%= emoji %>
                      </button>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
            <p class="mt-2 text-[#8696a0] text-xs">Dica: clique num emoji para inserir. Seus últimos usados viram favoritos.</p>
          </div>
        </div>

        <%# Attachment button %>
        <label class="p-2 text-[#8696a0] hover:text-white transition-colors cursor-pointer flex-shrink-0 mb-1"
               title="Anexar arquivo">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
          </svg>
          <%= f.file_field :attachment, class: "hidden",
                data: { action: "change->file-preview#showPreview", chat_target: "attachment" },
                accept: "image/*,audio/*,video/*,.pdf,.doc,.docx,.xls,.xlsx,.zip",
                multiple: true %>
        </label>

        <%# Sticker / GIF button (trigger only; panel is a fixed bottom-sheet) %>
        <div data-controller="sticker-picker"
             data-sticker-picker-send-path-value="<%= send_sticker_conversation_messages_path(@conversation) %>"
             data-sticker-picker-stickers-path-value="<%= stickers_path(format: :json) %>"
             data-sticker-picker-giphy-key-value="<%= ENV['GIPHY_API_KEY'].to_s %>"
             class="relative flex-shrink-0 mb-1">

          <button type="button"
                  data-action="click->sticker-picker#toggle"
                  class="p-2 text-[#8696a0] hover:text-white transition-colors"
                  title="Figurinhas & GIFs">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M14.5 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9.5L14.5 2z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6"/>
              <circle cx="9" cy="13" r="1.5" fill="currentColor"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 17c1.5-1.5 3-1.5 3 0"/>
            </svg>
          </button>

          <%# Hidden file input — lives here so Stimulus can find it as target %>
          <input type="file"
                 data-sticker-picker-target="uploadInput"
                 data-action="change->sticker-picker#onFileSelect"
                 accept="image/png,image/jpeg,image/gif,image/webp"
                 multiple class="hidden" />
        </div>

        <%# Text input %>
        <div class="flex-1 bg-[#2a3942] rounded-2xl px-4 py-2">
          <%= f.text_area :content,
                rows: 1,
                placeholder: "Digite uma mensagem",
                class: "w-full bg-transparent text-white placeholder-[#8696a0] text-sm outline-none resize-none max-h-32 leading-5",
                data: {
                  "composer-emoji-target": "input",
                  chat_target: "input",
                  action: "keydown->chat#handleKeydown input->chat#autoResize input->typing#handleTyping"
                } %>
        </div>

        <%# Send button — chat#submitForm disables during submit to avoid double send %>
        <button type="submit"
                data-chat-target="submitButton"
                class="p-2 bg-[#00a884] hover:bg-[#02966f] text-white rounded-full transition-colors flex-shrink-0 mb-1 disabled:opacity-70 disabled:cursor-not-allowed"
                title="Enviar">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
          </svg>
        </button>
      <% end %>
    </div>
  </div>

  <%# ── Sticker editor modal ────────────────────────────────────────────────── %>
  <div id="sticker-crop-modal"
       style="display:none; position:fixed; inset:0; z-index:600; align-items:center; justify-content:center; flex-direction:column;"
       aria-modal="true" role="dialog">
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.85); backdrop-filter:blur(4px);"></div>

    <div style="position:relative; margin:auto; width:100%; max-width:36rem; max-height:93vh; background:#1d2b32; border-radius:1rem; box-shadow:0 25px 60px rgba(0,0,0,0.7); display:flex; flex-direction:column; overflow:hidden;">

      <%# Header %>
      <div style="display:flex; align-items:center; justify-content:space-between; padding:12px 16px; border-bottom:1px solid #2a3942; flex-shrink:0;">
        <p style="color:#fff; font-weight:600; font-size:14px; margin:0;">Editor de figurinha</p>
        <button type="button" id="sticker-crop-close"
                style="color:#8696a0; background:none; border:none; cursor:pointer; font-size:20px; line-height:1; padding:4px;">✕</button>
      </div>

      <%# Tool tabs %>
      <div style="display:flex; border-bottom:1px solid #2a3942; flex-shrink:0;">
        <button type="button" id="editor-tab-crop"
                style="flex:1; padding:8px 0; font-size:12px; font-weight:600; color:#fff; border-bottom:2px solid #00a884; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:4px;">
          ✂️ Recortar
        </button>
        <button type="button" id="editor-tab-erase"
                style="flex:1; padding:8px 0; font-size:12px; font-weight:600; color:#8696a0; border-bottom:2px solid transparent; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:4px;">
          🖌️ Borracha
        </button>
        <button type="button" id="editor-tab-bg"
                style="flex:1; padding:8px 0; font-size:12px; font-weight:600; color:#8696a0; border-bottom:2px solid transparent; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:4px;">
          🪄 Remover fundo
        </button>
      </div>

      <%# ── CROP TOOL ── %>
      <div id="editor-pane-crop" style="display:flex; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
        <%# Shape toggle %>
        <div style="display:flex; align-items:center; gap:8px; padding:8px 16px; border-bottom:1px solid #2a3942; flex-shrink:0;">
          <span style="color:#8696a0; font-size:12px;">Forma:</span>
          <button type="button" id="crop-shape-free"
                  style="padding:3px 12px; border-radius:8px; font-size:12px; font-weight:500; background:#00a884; color:#fff; border:none; cursor:pointer;">Livre</button>
          <button type="button" id="crop-shape-square"
                  style="padding:3px 12px; border-radius:8px; font-size:12px; font-weight:500; background:#2a3942; color:#8696a0; border:none; cursor:pointer;">Quadrado</button>
          <button type="button" id="crop-shape-circle"
                  style="padding:3px 12px; border-radius:8px; font-size:12px; font-weight:500; background:#2a3942; color:#8696a0; border:none; cursor:pointer;">Círculo</button>
          <span style="margin-left:auto; color:#8696a0; font-size:10px;">Arraste · Scroll = zoom</span>
        </div>
        <div style="flex:1; min-height:280px; background:#0b141a; display:flex; align-items:center; justify-content:center; overflow:hidden;">
          <img id="sticker-crop-img" src="" alt="" style="display:none; max-width:100%;" />
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 16px; border-top:1px solid #2a3942; flex-shrink:0; gap:8px;">
          <button type="button" id="sticker-crop-reset"
                  style="padding:6px 12px; border-radius:10px; font-size:12px; color:#8696a0; border:1px solid #2a3942; background:none; cursor:pointer;">
            Resetar
          </button>
          <div style="display:flex; gap:8px; margin-left:auto;">
            <button type="button" id="sticker-crop-save"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#2a3942; color:#fff; border:none; cursor:pointer;">
              Salvar
            </button>
            <button type="button" id="sticker-crop-send"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#00a884; color:#fff; border:none; cursor:pointer;">
              Salvar e enviar
            </button>
          </div>
        </div>
      </div>

      <%# ── ERASE TOOL ── %>
      <div id="editor-pane-erase" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
        <%# Toolbar %>
        <div style="display:flex; align-items:center; gap:12px; padding:8px 16px; border-bottom:1px solid #2a3942; flex-shrink:0; flex-wrap:wrap;">
          <div style="display:flex; align-items:center; gap:8px;">
            <span style="color:#8696a0; font-size:12px;">Tamanho:</span>
            <input type="range" id="eraser-size" min="4" max="80" value="20"
                   style="width:96px; accent-color:#00a884;" />
            <span id="eraser-size-label" style="color:#fff; font-size:12px; width:24px;">20</span>
          </div>
          <div style="display:flex; align-items:center; gap:8px; margin-left:auto;">
            <button type="button" id="eraser-undo"
                    style="padding:4px 8px; border-radius:8px; font-size:12px; color:#8696a0; border:1px solid #2a3942; background:none; cursor:pointer;">
              ↩ Desfazer
            </button>
            <button type="button" id="eraser-clear"
                    style="padding:4px 8px; border-radius:8px; font-size:12px; color:#f87171; border:1px solid rgba(248,113,113,0.3); background:none; cursor:pointer;">
              Limpar tudo
            </button>
          </div>
        </div>
        <%# Canvas area %>
        <div style="flex:1; min-height:280px; background:#0b141a; display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative; cursor:none;">
          <canvas id="eraser-canvas"
                  style="display:block; touch-action:none; max-width:100%; max-height:100%;"></canvas>
          <div id="eraser-cursor"
               style="display:none; pointer-events:none; position:fixed; border-radius:50%; border:2px solid rgba(255,255,255,0.7); background:transparent; width:20px; height:20px; transform:translate(-50%,-50%);"></div>
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 16px; border-top:1px solid #2a3942; flex-shrink:0; gap:8px;">
          <span style="color:#8696a0; font-size:12px;">Pinte sobre o que quer apagar</span>
          <div style="display:flex; gap:8px;">
            <button type="button" id="eraser-save"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#2a3942; color:#fff; border:none; cursor:pointer;">
              Salvar
            </button>
            <button type="button" id="eraser-send"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#00a884; color:#fff; border:none; cursor:pointer;">
              Salvar e enviar
            </button>
          </div>
        </div>
      </div>

      <%# ── BG REMOVE TOOL ── %>
      <div id="editor-pane-bg" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
        <div style="display:flex; align-items:center; gap:12px; padding:8px 16px; border-bottom:1px solid #2a3942; flex-shrink:0; flex-wrap:wrap;">
          <div style="display:flex; align-items:center; gap:8px;">
            <span style="color:#8696a0; font-size:12px;">Tolerância:</span>
            <input type="range" id="bg-tolerance" min="5" max="100" value="30"
                   style="width:96px; accent-color:#00a884;" />
            <span id="bg-tolerance-label" style="color:#fff; font-size:12px; width:24px;">30</span>
          </div>
          <span style="color:#8696a0; font-size:12px; margin-left:8px;">Clique no fundo para remover</span>
          <button type="button" id="bg-undo"
                  style="margin-left:auto; padding:4px 8px; border-radius:8px; font-size:12px; color:#8696a0; border:1px solid #2a3942; background:none; cursor:pointer;">
            ↩ Desfazer
          </button>
        </div>
        <div style="flex:1; min-height:280px; background:#0b141a; display:flex; align-items:center; justify-content:center; overflow:hidden;">
          <canvas id="bg-canvas"
                  style="display:block; max-width:100%; max-height:100%; cursor:crosshair;"></canvas>
        </div>
        <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 16px; border-top:1px solid #2a3942; flex-shrink:0; gap:8px;">
          <span style="color:#8696a0; font-size:12px;">Clique nas áreas de fundo para torná-las transparentes</span>
          <div style="display:flex; gap:8px;">
            <button type="button" id="bg-save"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#2a3942; color:#fff; border:none; cursor:pointer;">
              Salvar
            </button>
            <button type="button" id="bg-send"
                    style="padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; background:#00a884; color:#fff; border:none; cursor:pointer;">
              Salvar e enviar
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%# ── Sticker overlay + bottom-sheet panel — outside every container so fixed positioning works ── %>
<div id="sticker-overlay"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:390; pointer-events:none;"></div>

<div id="sticker-panel"
     style="display:none; position:fixed; bottom:0; left:0; right:0; height:70vh; z-index:400; flex-direction:column; background:#1d2b32; border-top:1px solid #2a3942; border-radius:1.25rem 1.25rem 0 0; box-shadow:0 -8px 40px rgba(0,0,0,0.5);">

  <%# Drag handle %>
  <div style="display:flex; justify-content:center; padding:8px 0 4px; flex-shrink:0; cursor:grab;">
    <div style="width:40px; height:4px; border-radius:2px; background:#3d4a52;"></div>
  </div>

  <%# Tab bar %>
  <div style="display:flex; align-items:center; border-bottom:1px solid #2a3942; flex-shrink:0; padding:0 8px; gap:4px;">
    <button type="button" id="sp-tab-my"
            style="flex:1; padding:10px 0; font-size:14px; font-weight:600; color:#fff; border-bottom:2px solid #00a884; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer;">
      😄 Minhas
    </button>
    <button type="button" id="sp-tab-sticker"
            style="flex:1; padding:10px 0; font-size:14px; font-weight:600; color:#8696a0; border-bottom:2px solid transparent; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer;">
      ✨ Stickers
    </button>
    <button type="button" id="sp-tab-gif"
            style="flex:1; padding:10px 0; font-size:14px; font-weight:600; color:#8696a0; border-bottom:2px solid transparent; background:none; border-top:none; border-left:none; border-right:none; cursor:pointer;">
      🎬 GIFs
    </button>
    <div style="display:flex; align-items:center; gap:4px; padding-left:8px; padding-right:4px; flex-shrink:0;">
      <button type="button" id="sp-import-btn"
              style="color:#00a884; font-size:12px; padding:4px 8px; border-radius:8px; border:1px solid #00a884; background:none; cursor:pointer; font-weight:600; white-space:nowrap;">
        + Importar
      </button>
      <button type="button" id="sp-close-btn"
              style="color:#8696a0; background:none; border:none; cursor:pointer; font-size:20px; line-height:1; padding:4px;">✕</button>
    </div>
  </div>

  <%# Progress bar %>
  <div id="sp-progress" style="display:none; padding:8px 16px; flex-shrink:0; border-bottom:1px solid #2a3942;">
    <div style="display:flex; justify-content:space-between; font-size:12px; color:#8696a0; margin-bottom:4px;">
      <span id="sp-progress-label">Importando…</span>
      <span id="sp-progress-count"></span>
    </div>
    <div style="width:100%; background:#2a3942; border-radius:4px; height:6px;">
      <div id="sp-progress-bar" style="width:0%; background:#00a884; height:6px; border-radius:4px; transition:width 0.3s;"></div>
    </div>
  </div>

  <%# MY STICKERS pane %>
  <div id="sp-pane-my" style="display:flex; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
    <p style="color:#8696a0; font-size:12px; padding:8px 16px 4px; flex-shrink:0;">
      Clique para enviar · Passe o mouse para editar/apagar
    </p>
    <div id="sp-grid"
         style="overflow-y:auto; flex:1; padding:12px 12px 20px; display:grid; gap:12px; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); align-content:start;">
      <p style="color:#8696a0;font-size:12px;text-align:center;grid-column:1/-1;padding:32px 0;">Carregando…</p>
    </div>
  </div>

  <%# GIPHY STICKERS pane %>
  <div id="sp-pane-sticker" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
    <div style="padding:8px 16px; flex-shrink:0; border-bottom:1px solid #2a3942;">
      <div style="display:flex; align-items:center; background:#2a3942; border-radius:12px; padding:8px 12px; gap:8px;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;color:#8696a0;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <input type="text" id="sp-sticker-search" placeholder="Buscar stickers (GIPHY)…"
               style="background:none; color:#fff; font-size:14px; outline:none; width:100%; border:none;" />
      </div>
    </div>
    <div id="sp-sticker-grid"
         style="overflow-y:auto; padding:12px; display:grid; gap:8px; grid-template-columns:repeat(auto-fill,minmax(100px,1fr)); align-content:start; flex:1;">
      <p style="color:#8696a0;font-size:12px;text-align:center;grid-column:1/-1;padding:32px 0;">Carregando stickers…</p>
    </div>
    <div style="flex-shrink:0; padding:6px 16px; border-top:1px solid #2a3942; display:flex; align-items:center; justify-content:flex-end; gap:4px;">
      <span style="color:#8696a0;font-size:10px;">Powered by</span>
      <span style="color:#fff;font-size:10px;font-weight:700;letter-spacing:0.05em;">GIPHY</span>
    </div>
  </div>

  <%# GIF pane %>
  <div id="sp-pane-gif" style="display:none; flex-direction:column; flex:1; min-height:0; overflow:hidden;">
    <div style="padding:8px 16px; flex-shrink:0; border-bottom:1px solid #2a3942;">
      <div style="display:flex; align-items:center; background:#2a3942; border-radius:12px; padding:8px 12px; gap:8px;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width:16px;height:16px;color:#8696a0;flex-shrink:0;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z"/>
        </svg>
        <input type="text" id="sp-gif-search" placeholder="Buscar GIFs…"
               style="background:none; color:#fff; font-size:14px; outline:none; width:100%; border:none;" />
      </div>
    </div>
    <div id="sp-gif-grid"
         style="overflow-y:auto; padding:12px; display:grid; gap:8px; grid-template-columns:1fr 1fr; align-content:start; flex:1;">
      <p style="color:#8696a0;font-size:12px;text-align:center;grid-column:1/-1;padding:32px 0;">Carregando GIFs em alta…</p>
    </div>
    <div style="flex-shrink:0; padding:6px 16px; border-top:1px solid #2a3942; display:flex; align-items:center; justify-content:flex-end; gap:4px;">
      <span style="color:#8696a0;font-size:10px;">Powered by</span>
      <span style="color:#fff;font-size:10px;font-weight:700;letter-spacing:0.05em;">GIPHY</span>
    </div>
  </div>
</div>

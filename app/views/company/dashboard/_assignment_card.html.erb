<%# Single assignment card for the live inbox %>
<% conv = assignment.conversation %>
<% customer = conv.users.where.not(id: assignment.company.owner_id)
                         .where.not(id: assignment.company.attendant_users.select(:id))
                         .first %>

<div class="bg-[#202c33] rounded-lg p-3 shadow hover:bg-[#263038] transition-colors"
     id="assignment-<%= assignment.id %>"
     data-company-inbox-target="card"
     data-assignment-id="<%= assignment.id %>">

  <div class="flex items-start justify-between gap-2">
    <div class="flex items-center gap-2 min-w-0">
      <div class="w-8 h-8 rounded-full bg-[#6a7175] flex items-center justify-center text-white font-semibold text-xs flex-shrink-0">
        <%= customer&.display_name&.first&.upcase || "?" %>
      </div>
      <div class="min-w-0">
        <p class="text-white text-xs font-semibold truncate">
          <%= customer&.display_name || "Cliente" %>
        </p>
        <% if customer&.nickname.present? %>
          <p class="text-[#8696a0] text-xs">@<%= customer.nickname %></p>
        <% end %>
      </div>
    </div>
    <p class="text-[#8696a0] text-xs flex-shrink-0"><%= assignment.created_at.strftime("%H:%M") %></p>
  </div>

  <% if assignment.selected_department.present? %>
    <div class="mt-2 flex items-center gap-1">
      <span class="bg-[#00a884]/20 text-[#00a884] text-xs px-2 py-0.5 rounded-full">
        <%= assignment.selected_department %>
      </span>
    </div>
  <% end %>

  <% if assignment.company_attendant %>
    <p class="text-[#8696a0] text-xs mt-2">
      Atendente: <span class="text-[#d1d7db]"><%= assignment.company_attendant.user.display_name %></span>
    </p>
  <% end %>

  <% last_msg = conv.messages.order(sequence: :desc).first %>
  <% if last_msg %>
    <p class="text-[#8696a0] text-xs mt-1 truncate">"<%= last_msg.content&.truncate(50) %>"</p>
  <% end %>

  <div class="mt-3 flex items-center gap-2 flex-wrap">
    <%= link_to company_assignment_path(assignment), class: "text-[#58a6ff] text-xs hover:underline" do %>
      Detalhes do ticket
    <% end %>
    <% if current_user.role_admin? || assignment.company.supervisor?(current_user) %>
      <%= link_to admin_conversation_path(conv, mode: "monitor", scope: "company", company_id: assignment.company_id), class: "text-amber-400 text-xs hover:underline", data: { turbo_frame: "_top" } do %>
        Ver chat (admin)
      <% end %>
    <% end %>
  </div>
</div>

<%# Sender sees the new message(s) immediately. Others receive via ActionCable. %>
<% if @messages.present? %>
  <% @messages.each do |msg| %>
    <%= turbo_stream.append "messages" do %>
      <%= render "messages/message", message: msg, current_user: current_user %>
    <% end %>
  <% end %>
<% else %>
  <%= turbo_stream.append "messages" do %>
    <%= render "messages/message", message: @message, current_user: current_user %>
  <% end %>
<% end %>
